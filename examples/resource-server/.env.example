# ============================================================
# x401 Resource Server — environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# Port the server listens on
PORT=3000

# Zetrix network — derives the OID4VP base URL: zetrix:testnet -> sandbox, zetrix:mainnet -> prod
X401_NETWORK=zetrix:testnet

# Optional: pin the OID4VP base URL explicitly (overrides X401_NETWORK)
# X401_OID4VP_BASE_URL=https://zid-oid4vp-sandbox.zetrix.com/api

# Bearer `ztx_...` API key that authenticates verification-request creation
X401_API_KEY=ztx_your_api_key

# Shared HMAC secret used to verify the PROOF-RESPONSE (never commit the real value)
X401_CALLBACK_SECRET=your-shared-callback-secret
