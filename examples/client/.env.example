# ============================================================
# x401 Client (wallet/holder) — environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# Zetrix network — derives the OID4VP base URL (same backend the resource server points at)
X401_NETWORK=zetrix:testnet

# Optional: pin the OID4VP base URL explicitly (overrides X401_NETWORK)
# X401_OID4VP_BASE_URL=https://zid-oid4vp-sandbox.zetrix.com/api

# Holder DID (default: did:zid:holder)
X401_HOLDER_DID=did:zid:holder

# The PROOF-REQUEST header value to answer (from a resource server's 401 response)
X401_PROOF_REQUEST=
